<!DOCTYPE html>
<html lang="pt-br" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>J NINE | Hub Oficial</title>
    <meta name="description" content="Hub oficial do J Nine — Singles, Álbuns, Composições e Negócios.">

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;700;900&family=Playfair+Display:ital,wght@1,700&family=JetBrains+Mono&display=swap" rel="stylesheet">

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#c5a059',      /* Gold/Bronze */
                        dark: '#0d0b0a',         /* Dark Brown/Black */
                        card: '#161311',         /* Surface Brown */
                        surface: '#1c1815',
                    },
                    fontFamily: {
                        sans: ['Outfit', 'sans-serif'],
                        drama: ['Playfair Display', 'serif'],
                        mono: ['JetBrains Mono', 'monospace'],
                    }
                }
            }
        }
    </script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
    <script src="https://unpkg.com/lucide@latest"></script>

    <style>
        :root { --primary: #c5a059; --dark: #0d0b0a; --card: #161311; }
        body { background: var(--dark); cursor: default; }

        .noise { position: fixed; top:0; left:0; width:100%; height:100%; background-image:url('https://grainy-gradients.vercel.app/noise.svg'); opacity:0.04; pointer-events:none; z-index:9999; }

        .btn-gold {
            display: inline-flex; align-items: center; gap: 10px;
            padding: 16px 36px; border-radius: 100px;
            background: var(--primary); color: white;
            font-weight: 800; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase;
            transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
            box-shadow: 0 10px 30px rgba(197, 160, 89, 0.2);
        }
        .btn-gold:hover { transform: translateY(-3px) scale(1.02); box-shadow: 0 20px 50px rgba(197, 160, 89, 0.3); }

        .btn-outline {
            display: inline-flex; align-items: center; gap: 10px;
            padding: 16px 36px; border-radius: 100px;
            background: transparent; color: rgba(255,255,255,0.6);
            font-weight: 800; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase;
            border: 1px solid rgba(255,255,255,0.1);
            transition: all 0.4s;
        }
        .btn-outline:hover { border-color: var(--primary); color: white; background: rgba(197, 160, 89, 0.05); }

        .track-card {
            background: var(--card);
            border: 1px solid rgba(255,255,255,0.03);
            border-radius: 2.5rem;
            overflow: hidden;
            transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
        }
        .track-card:hover { border-color: rgba(197, 160, 89, 0.2); transform: translateY(-8px); }
        .track-card img { filter: grayscale(100%) contrast(1.1); transition: filter 0.8s, transform 0.8s; }
        .track-card:hover img { filter: grayscale(0%); transform: scale(1.05); }

        .pill {
            padding: 6px 14px; border-radius: 100px; border: 1px solid rgba(255,255,255,0.08);
            background: rgba(255,255,255,0.02); font-size: 10px; font-weight: 800; text-transform: uppercase;
        }

        .marquee-inner { display: inline-flex; animation: marquee 60s linear infinite; }
        @keyframes marquee { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }

        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-thumb { background: var(--primary); border-radius: 10px; }

        .text-drama { font-family: 'Playfair Display', serif; font-style: italic; }
    </style>
</head>
<body class="antialiased text-white overflow-x-hidden font-sans selection:bg-primary selection:text-white">
    <div class="noise"></div>

    <!-- CONFIG -->
    <script>
        const CONFIG = {
            artist: "J NINE",
            branding: "JOTTANINE",
            label: "Carrera's Produções",
            discography: [
                {
                    title: "Luz Púrpura",
                    type: "Single",
                    cover: "https://images.unsplash.com/photo-1614613535308-eb5fbd3d2c17?q=80&w=800",
                    links: { spotify: "#", youtube: "#", apple: "#", deezer: "#" }
                },
                {
                    title: "Noites Curtas",
                    type: "Feat",
                    cover: "https://images.unsplash.com/photo-1598488035139-bdbb2231ce04?q=80&w=800",
                    links: { spotify: "#", youtube: "#", apple: "#" }
                },
                {
                    title: "Ciclos",
                    type: "Álbum",
                    cover: "https://images.unsplash.com/photo-1470225620780-dba8ba36b745?q=80&w=800",
                    links: { spotify: "#", apple: "#", youtube: "#" }
                }
            ],
            compositions: [
                {
                    title: "Diamante Bruto",
                    artist: "Artista Convidado",
                    cover: "https://images.unsplash.com/photo-1493225255756-d9584f8606e9?q=80&w=800",
                    links: { spotify: "#", youtube: "#" }
                },
                {
                    title: "Sombra do Amanhã",
                    artist: "Feat. Especial",
                    cover: "https://images.unsplash.com/photo-1511671782779-c97d3d27a1d4?q=80&w=800",
                    links: { spotify: "#", apple: "#" }
                }
            ],
            videos: [
                { title: "Clipe Oficial: Luz Púrpura", type: "Music Video", id: "dQw4w9WgXcQ" },
                { title: "Bastidores: Ciclos (Doc)", type: "Behind the Scenes", id: "dQw4w9WgXcQ" },
                { title: "Ao Vivo no Studio 18h", type: "Live Performance", id: "dQw4w9WgXcQ" }
            ]
        };
    </script>

    <!-- NAVBAR -->
    <nav id="navbar" class="fixed top-6 left-1/2 -translate-x-1/2 z-[100] w-[92%] max-w-4xl px-8 py-4 rounded-full border border-white/5 bg-dark/60 backdrop-blur-3xl flex justify-between items-center transition-all duration-500">
        <span class="font-black tracking-tighter text-2xl">J NINE</span>
        <div class="hidden md:flex gap-8 text-[9px] font-black uppercase tracking-[0.25em] text-white/30">
            <a href="#music" class="hover:text-primary transition-colors">Obras</a>
            <a href="#compositions" class="hover:text-primary transition-colors">Compositiva</a>
            <a href="#videos" class="hover:text-primary transition-colors">Visual</a>
            <a href="#business" class="hover:text-primary transition-colors">Negócios</a>
        </div>
        <button onclick="toggleMobileMenu()" class="md:hidden p-2 rounded-xl bg-white/5">
            <i data-lucide="menu" class="w-5 h-5"></i>
        </button>
        <div class="hidden md:block w-2 h-2 rounded-full bg-primary shadow-[0_0_12px_rgba(197,160,89,0.9)] animate-pulse"></div>
    </nav>

    <!-- HERO -->
    <header class="relative min-h-screen flex flex-col justify-end pb-24 px-6 md:px-20 overflow-hidden">
        <!-- BACKGROUND PHOTO (Hand on face) -->
        <div class="absolute inset-0 z-0">
            <img src="J-rosto.jpeg" class="w-full h-full object-cover object-center" alt="J NINE">
            <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(13,11,10,0.2) 0%, rgba(13,11,10,0.6) 60%, rgba(13,11,10,1) 100%);"></div>
            <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(13,11,10,0.8) 0%, transparent 50%);"></div>
        </div>

        <div class="relative z-10 max-w-5xl space-y-12">
            <p class="font-mono text-[10px] tracking-[0.7em] text-primary uppercase reveal-up">Artista & Compositor · Lifestyle</p>
            <h1 class="text-[clamp(6rem,16vw,14rem)] font-black tracking-tighter leading-[0.8] reveal-up uppercase">
                JOTTA<br><span class="text-primary">NINE.</span>
            </h1>
            <p class="text-white/50 text-xl md:text-2xl text-drama max-w-lg leading-relaxed reveal-up">
                "A caneta é o meu instrumento.<br>Do Underground às paradas de sucesso."
            </p>
            <div class="flex flex-wrap gap-6 reveal-up">
                <a href="#music" class="btn-gold">Ouça os Lançamentos</a>
                <a href="#business" class="btn-outline">Booking & Rights</a>
            </div>
        </div>
    </header>

    <!-- STATS BAR -->
    <section class="py-12 border-y border-white/5 bg-zinc-950/50 backdrop-blur">
        <div class="max-w-5xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-10 text-center reveal-up">
            <div>
                <p class="text-4xl font-black text-primary">500k+</p>
                <p class="font-mono text-[9px] text-white/30 uppercase tracking-[0.4em] mt-2">Streams Totais</p>
            </div>
            <div>
                <p class="text-4xl font-black text-primary">150+</p>
                <p class="font-mono text-[9px] text-white/30 uppercase tracking-[0.4em] mt-2">Composições</p>
            </div>
            <div>
                <p class="text-4xl font-black text-primary">12+</p>
                <p class="font-mono text-[9px] text-white/30 uppercase tracking-[0.4em] mt-2">Colaborações</p>
            </div>
            <div>
                <p class="text-4xl font-black text-primary">SP/BR</p>
                <p class="font-mono text-[9px] text-white/30 uppercase tracking-[0.4em] mt-2">Base Oficial</p>
            </div>
        </div>
    </section>

    <!-- SPOTIFY PLAYER (Directly below stats) -->
    <section class="py-16 px-6 bg-dark">
        <div class="max-w-4xl mx-auto reveal-up">
            <iframe style="border-radius:30px" src="https://open.spotify.com/embed/artist/37i9dQZF1DXcBWIGoYBM3M?utm_source=generator&theme=0" width="100%" height="200" frameBorder="0" allowfullscreen="" loading="lazy"></iframe>
        </div>
    </section>

    <!-- PRE-SAVE / SECRET DROP -->
    <section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden border-y border-white/5">
        <img src="J-nine-costa.jpeg" class="absolute inset-0 w-full h-full object-cover object-top opacity-40" alt="J NINE BACK">
        <div class="absolute inset-0" style="background: linear-gradient(to bottom, var(--dark) 0%, transparent 40%, transparent 60%, var(--dark) 100%);"></div>
        
        <div class="relative z-10 text-center space-y-8 px-6 max-w-2xl reveal-up">
            <p class="font-mono text-[10px] uppercase tracking-[0.8em] text-primary">Upcoming Drop</p>
            <h2 class="text-5xl md:text-7xl font-black uppercase tracking-tighter">LIBERDADE <br><span class="text-drama text-white/20">SENTIMENTOS.</span></h2>
            <p class="text-white/40 text-sm md:text-base leading-relaxed">O próximo capítulo da caminhada está sendo escrito. Deixe seu contato para garantir acesso antecipado ao pre-save exclusivo.</p>
            <form class="flex flex-col md:flex-row gap-3 pt-4">
                <input type="tel" placeholder="Seu WhatsApp" class="flex-1 bg-white/5 border border-white/10 rounded-full py-4 px-8 text-sm font-bold focus:border-primary focus:outline-none transition-all">
                <button class="btn-gold py-4 px-10">Garantir VIP Access</button>
            </form>
        </div>
    </section>

    <!-- PLATFORM MARQUEE -->
    <div class="py-10 bg-dark overflow-hidden border-b border-white/5">
        <div class="marquee-inner whitespace-nowrap opacity-20 hover:opacity-100 transition-opacity">
            <span class="mx-16 text-xs font-black uppercase tracking-[0.5em]">■ Spotify</span>
            <span class="mx-16 text-xs font-black uppercase tracking-[0.5em] text-primary">■ YouTube Music</span>
            <span class="mx-16 text-xs font-black uppercase tracking-[0.5em]">■ Apple Music</span>
            <span class="mx-16 text-xs font-black uppercase tracking-[0.5em] text-primary">■ Deezer</span>
            <span class="mx-16 text-xs font-black uppercase tracking-[0.5em]">■ Tidal</span>
            <span class="mx-16 text-xs font-black uppercase tracking-[0.5em] text-primary">■ Amazon Music</span>
        </div>
    </div>

    <!-- DISCOGRAPHY — "NFT Trend" style -->
    <section id="music" class="py-32 bg-dark">
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
                <div class="reveal-up">
                    <span class="font-mono text-[10px] uppercase tracking-[0.5em] text-primary/60">Discografia</span>
                    <h2 class="text-5xl md:text-7xl font-black uppercase tracking-tighter mt-2">Hot <span class="text-drama text-primary">Trending.</span></h2>
                    <p class="text-white/20 text-sm mt-4 max-w-sm">Os lançamentos que estão definindo a nova era do J NINE.</p>
                </div>
                <div class="flex gap-2 p-1.5 bg-zinc-900/40 border border-white/5 rounded-2xl reveal-up shrink-0 flex-wrap">
                    <button onclick="filterMusic('Tudo')" class="filter-btn px-6 py-2.5 bg-primary text-white font-black rounded-xl text-[9px] uppercase transition-all whitespace-nowrap">Tudo</button>
                    <button onclick="filterMusic('Álbum')" class="filter-btn px-6 py-2.5 text-white/30 font-black rounded-xl text-[9px] uppercase hover:text-white transition-all whitespace-nowrap">Álbuns</button>
                    <button onclick="filterMusic('Single')" class="filter-btn px-6 py-2.5 text-white/30 font-black rounded-xl text-[9px] uppercase hover:text-white transition-all whitespace-nowrap">Singles</button>
                </div>
            </div>

            <div id="discography-grid" class="grid grid-cols-2 md:grid-cols-4 gap-6"></div>
        </div>
    </section>

    <!-- COMPOSITIONS — Exclusive Writer Hub -->
    <section id="compositions" class="py-32 bg-zinc-950 px-6">
        <div class="max-w-7xl mx-auto">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
                <div class="reveal-up">
                    <p class="font-mono text-[9px] uppercase tracking-[0.7em] text-primary/60 mb-4">Writer Experience</p>
                    <h2 class="text-5xl md:text-7xl font-black uppercase tracking-tighter">Obras <br><span class="text-drama italic text-primary">Compostas.</span></h2>
                    <p class="text-white/30 mt-6 max-w-lg leading-relaxed">Letras, métricas e melodias que ganharam voz em diversos artistas do cenário nacional.</p>
                    <div class="flex gap-4 pt-8">
                        <a href="#business" class="btn-gold">Contratar Composição</a>
                    </div>
                </div>
                <div id="compositions-grid" class="grid grid-cols-2 gap-4"></div>
            </div>
        </div>
    </section>

    <!-- VIDEO HUB — Stage Focus -->
    <section id="videos" class="relative py-32 bg-dark px-6 overflow-hidden">
        <div class="max-w-7xl mx-auto relative z-10">
            <div class="mb-16 reveal-up">
                <h2 class="text-5xl md:text-7xl font-black uppercase tracking-tighter">Visual <br><span class="text-drama text-primary italic">Statement.</span></h2>
            </div>
            
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
                <div class="lg:col-span-8 reveal-up">
                    <div class="aspect-video rounded-[3rem] overflow-hidden border border-white/5 shadow-2xl relative group h-full">
                        <div id="main-video-poster" class="w-full h-full relative cursor-pointer" onclick="playMainVideo()">
                            <img src="J-nine-foto.jpeg" class="w-full h-full object-cover opacity-60 group-hover:scale-105 transition-transform duration-1000" id="main-video-thumb">
                            <div class="absolute inset-0 flex items-center justify-center">
                                <div class="w-20 h-20 rounded-full bg-primary/80 backdrop-blur flex items-center justify-center shadow-2xl hover:scale-110 transition-transform">
                                    <i data-lucide="play" class="text-white w-8 h-8 fill-white ml-1"></i>
                                </div>
                            </div>
                        </div>
                        <iframe id="main-video-frame" class="w-full h-full hidden" frameborder="0" allowfullscreen allow="autoplay; encrypted-media"></iframe>
                    </div>
                </div>
                <div class="lg:col-span-4 flex flex-col gap-4 max-h-[500px] overflow-y-auto pr-2" id="video-side-grid"></div>
            </div>
        </div>
    </section>

    <!-- BUSINESS HUB — Carrera's Produções -->
    <section id="business" class="py-40 bg-zinc-950 px-6 relative overflow-hidden">
        <div class="max-w-5xl mx-auto relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
            <div class="space-y-12">
                <div class="reveal-up">
                    <h2 class="text-5xl md:text-8xl font-black uppercase leading-[0.9]">Hub de <br> <span class="text-drama italic text-primary">Negócios.</span></h2>
                    <p class="text-white/40 mt-8 text-xl leading-relaxed">Conexão direta para contratações, composições e parcerias através da <span class="text-white font-bold tracking-widest">CARRERA’S PRODUÇÕES</span>.</p>
                </div>
                <div class="space-y-8 reveal-up">
                    <div class="flex gap-6 items-start p-6 rounded-3xl bg-white/[0.02] border border-white/5">
                        <div class="p-4 bg-primary/10 rounded-2xl border border-primary/20 shrink-0"><i data-lucide="mic" class="text-primary w-5 h-5"></i></div>
                        <div><h4 class="font-black text-lg uppercase">Shows</h4><p class="text-sm text-white/30 mt-1">Tour nacional e performances lives.</p></div>
                    </div>
                    <div class="flex gap-6 items-start p-6 rounded-3xl bg-white/[0.02] border border-white/5">
                        <div class="p-4 bg-primary/10 rounded-2xl border border-primary/20 shrink-0"><i data-lucide="pen-tool" class="text-primary w-5 h-5"></i></div>
                        <div><h4 class="font-black text-lg uppercase">Composição</h4><p class="text-sm text-white/30 mt-1">Sessões de escrita e licenciamento.</p></div>
                    </div>
                </div>
            </div>

            <form class="p-10 md:p-14 rounded-[4rem] bg-card border border-white/5 space-y-6 reveal-up">
                <div class="space-y-2">
                    <label class="text-[9px] font-black uppercase text-white/20 tracking-[0.2em] ml-1">Assunto</label>
                    <select class="w-full bg-zinc-900 border border-white/5 rounded-3xl py-5 px-8 text-sm font-bold text-white focus:border-primary focus:outline-none appearance-none cursor-pointer">
                        <option>CONTRATAR SHOWS</option>
                        <option>SOLICITAR COMPOSIÇÃO</option>
                        <option>FEAT / COLAB</option>
                    </select>
                </div>
                <input type="text" placeholder="Seu Nome ou Empresa" class="w-full bg-white/5 border border-white/10 rounded-3xl py-5 px-8 text-sm font-bold focus:border-primary transition-all focus:outline-none">
                <input type="tel" placeholder="WhatsApp para Contato" class="w-full bg-white/5 border border-white/10 rounded-3xl py-5 px-8 text-sm font-bold focus:border-primary transition-all focus:outline-none">
                <button class="w-full py-6 bg-primary text-white font-black rounded-3xl shadow-2xl shadow-primary/20 hover:scale-[1.02] transition-all uppercase tracking-widest text-[10px]">Enviar Proposta</button>
            </form>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="py-24 bg-dark text-center border-t border-white/5 px-6">
        <h2 class="text-[15vw] font-black uppercase select-none leading-none mb-12 opacity-[0.03]">JOTTANINE</h2>
        <div class="flex justify-center gap-8 mb-12 flex-wrap">
            <a href="#" class="text-white/20 hover:text-primary transition-all font-bold uppercase text-[10px] tracking-widest">Spotify</a>
            <a href="#" class="text-white/20 hover:text-primary transition-all font-bold uppercase text-[10px] tracking-widest">YouTube</a>
            <a href="#" class="text-white/20 hover:text-primary transition-all font-bold uppercase text-[10px] tracking-widest">Instagram</a>
        </div>
        <p class="text-[10px] font-mono text-white/20 uppercase tracking-[0.5em]">2024 · CARRERA'S PRODUÇÕES · HUB OFICIAL</p>
    </footer>

    <!-- SCRIPT ENGINE -->
    <script>
        lucide.createIcons();
        gsap.registerPlugin(ScrollTrigger);

        function renderDiscography(filter = 'Tudo') {
            const grid = document.getElementById('discography-grid');
            grid.innerHTML = '';
            const items = filter === 'Tudo' ? CONFIG.discography : CONFIG.discography.filter(i => i.type === filter);
            items.forEach((item) => {
                const card = document.createElement('div');
                card.className = "track-card reveal-up relative aspect-square overflow-hidden group";
                card.innerHTML = `
                    <img src="${item.cover}" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000">
                    <div class="absolute inset-0 bg-gradient-to-t from-dark/90 to-transparent flex flex-col justify-end p-6 translate-y-4 group-hover:translate-y-0 transition-transform">
                        <span class="text-[8px] font-black text-primary uppercase tracking-widest">${item.type}</span>
                        <h4 class="text-xl font-black uppercase leading-tight mt-1">${item.title}</h4>
                        <div class="flex gap-2 mt-4 opacity-0 group-hover:opacity-100 transition-opacity">
                            <span class="pill text-[8px]">Ouvir Agora</span>
                        </div>
                    </div>
                `;
                grid.appendChild(card);
            });
        }

        function renderCompositions() {
            const grid = document.getElementById('compositions-grid');
            grid.innerHTML = '';
            CONFIG.compositions.forEach((item) => {
                const card = document.createElement('div');
                card.className = "track-card reveal-up aspect-square relative group overflow-hidden border-none";
                card.innerHTML = `
                    <img src="${item.cover}" class="absolute inset-0 w-full h-full object-cover grayscale brightness-50">
                    <div class="absolute inset-0 p-6 flex flex-col justify-between">
                        <div class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center backdrop-blur"><i data-lucide="pen-tool" class="w-3 h-3 text-primary"></i></div>
                        <div>
                            <span class="text-[8px] font-black text-white/40 uppercase tracking-widest">Interpretada por ${item.artist}</span>
                            <h4 class="text-lg font-black uppercase mt-1">${item.title}</h4>
                        </div>
                    </div>
                `;
                grid.appendChild(card);
            });
            lucide.createIcons();
        }

        let currentVideoId = CONFIG.videos[0].id;
        function playMainVideo(id) {
            if (id) currentVideoId = id;
            document.getElementById('main-video-poster').classList.add('hidden');
            const frame = document.getElementById('main-video-frame');
            frame.classList.remove('hidden');
            frame.src = `https://www.youtube.com/embed/${currentVideoId}?autoplay=1`;
        }

        function renderVideos() {
            const vGrid = document.getElementById('video-side-grid');
            vGrid.innerHTML = '';
            CONFIG.videos.forEach((v) => {
                const thumb = `https://img.youtube.com/vi/${v.id}/hqdefault.jpg`;
                const row = document.createElement('div');
                row.className = "p-4 rounded-[2rem] bg-card border border-white/5 flex gap-5 cursor-pointer group hover:border-primary/30 transition-all";
                row.onclick = () => {
                    const frame = document.getElementById('main-video-frame');
                    if (frame.classList.contains('hidden')) {
                        document.getElementById('main-video-thumb').src = thumb;
                        currentVideoId = v.id;
                    } else {
                        frame.src = `https://www.youtube.com/embed/${v.id}?autoplay=1`;
                    }
                };
                row.innerHTML = `
                    <div class="w-24 h-16 rounded-2xl overflow-hidden relative shrink-0">
                        <img src="${thumb}" class="w-full h-full object-cover group-hover:scale-110 transition-transform">
                        <div class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity"><i data-lucide="play" class="w-4 h-4 fill-white text-white"></i></div>
                    </div>
                    <div class="flex flex-col justify-center overflow-hidden">
                        <h5 class="text-[10px] font-black uppercase leading-tight truncate">${v.title}</h5>
                        <p class="text-[8px] text-primary uppercase mt-1 tracking-widest font-bold">${v.type}</p>
                    </div>
                `;
                vGrid.appendChild(row);
            });
            lucide.createIcons();
        }

        function filterMusic(type) {
            document.querySelectorAll('.filter-btn').forEach(b => {
                b.classList.remove('bg-primary', 'text-white');
                b.classList.add('text-white/30');
            });
            event.target.classList.add('bg-primary', 'text-white');
            event.target.classList.remove('text-white/30');
            renderDiscography(type);
        }

        function toggleMobileMenu() {
            // Basic mobile menu toggle logic
        }

        // Init
        renderDiscography();
        renderCompositions();
        renderVideos();

        // Reveal animations
        gsap.utils.toArray('.reveal-up').forEach(el => {
            gsap.from(el, { scrollTrigger: { trigger: el, start: "top 95%" }, y: 50, opacity: 0, duration: 1.5, ease: 'expo.out' });
        });

        // Magnetic Effect
        document.querySelectorAll('.btn-gold, .btn-outline').forEach(btn => {
            btn.addEventListener('mousemove', e => {
                const r = btn.getBoundingClientRect();
                const x = (e.clientX - r.left - r.width/2) * 0.3;
                const y = (e.clientY - r.top - r.height/2) * 0.3;
                btn.style.transform = `translate(${x}px, ${y}px)`;
            });
            btn.addEventListener('mouseleave', () => btn.style.transform = 'translate(0,0)');
        });
    </script>
</body>
</html>
